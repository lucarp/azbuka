    { "id": "S-05", "type": "phrase", "category": "survival", "front": { "text": "Onde fica o banheiro?", "language": "pt" }, "back": { "text": "Где туалет?", "language": "ru", "transliteration": "Gdié tualiét?", "note": "'Где' significa 'onde' — memorize, é útil." }, "createdBy": "seed" },
    { "id": "S-06", "type": "phrase", "category": "survival", "front": { "text": "Um café, por favor", "language": "pt" }, "back": { "text": "Один кофе, пожалуйста", "language": "ru", "transliteration": "Odín kófie, pojálusta", "note": "Truque: кофе é indeclinável, fácil de usar." }, "createdBy": "seed" },
    { "id": "S-07", "type": "phrase", "category": "survival", "front": { "text": "A conta, por favor", "language": "pt" }, "back": { "text": "Счёт, пожалуйста", "language": "ru", "transliteration": "Schiót, pojálusta", "note": "Também se pode fazer o gesto universal de rabiscar no ar." }, "createdBy": "seed" },
    { "id": "S-08", "type": "phrase", "category": "survival", "front": { "text": "Eu quero...", "language": "pt" }, "back": { "text": "Я хочу...", "language": "ru", "transliteration": "Ya khochú...", "note": "Funcional mas direto. Mais educado: 'Я хотел бы' (queria)." }, "createdBy": "seed" },
    { "id": "S-09", "type": "phrase", "category": "survival", "front": { "text": "Tenho alergia", "language": "pt" }, "back": { "text": "У меня аллергия", "language": "ru", "transliteration": "U miniá alliérgia", "note": "Literalmente 'comigo [existe] alergia'. Adicione o alimento depois." }, "createdBy": "seed" },
    { "id": "S-10", "type": "phrase", "category": "survival", "front": { "text": "Não falo russo", "language": "pt" }, "back": { "text": "Я не говорю по-русски", "language": "ru", "transliteration": "Ya ne govoriú po-rússki", "note": "Ironicamente, se você sabe dizer isto, já fala um pouco." }, "createdBy": "seed" },
    { "id": "S-11", "type": "phrase", "category": "survival", "front": { "text": "Você fala inglês?", "language": "pt" }, "back": { "text": "Вы говорите по-английски?", "language": "ru", "transliteration": "Vy govorítie po-anglíiski?", "note": "Formal. Informal: 'Ты говоришь…'" }, "createdBy": "seed" },
    { "id": "S-12", "type": "phrase", "category": "survival", "front": { "text": "Hoje / amanhã", "language": "pt" }, "back": { "text": "Сегодня / завтра", "language": "ru", "transliteration": "Sievódnia / závtra", "note": "Em сегодня o 'г' soa como 'v' — irregularidade clássica." }, "createdBy": "seed" },
    { "id": "S-13", "type": "phrase", "category": "survival", "front": { "text": "Água", "language": "pt" }, "back": { "text": "Вода", "language": "ru", "transliteration": "Vadá", "note": "Tônica no fim; o 'о' átono vira 'a'. Com gás: 'с газом' (s gázom)." }, "createdBy": "seed" },
    { "id": "S-14", "type": "phrase", "category": "survival", "front": { "text": "Socorro!", "language": "pt" }, "back": { "text": "Помогите!", "language": "ru", "transliteration": "Pomogítie!", "note": "Grite forte. Não é a mesma palavra que 'me ajude' do cotidiano — o tom muda tudo." }, "createdBy": "seed" },
    { "id": "S-15", "type": "phrase", "category": "survival", "front": { "text": "Estou perdido", "language": "pt" }, "back": { "text": "Я заблудился", "language": "ru", "transliteration": "Ya zabludílsia", "note": "Masculino. Feminino: заблудилась (zabludílas')." }, "createdBy": "seed" },

    { "id": "N-01", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Um (1)", "language": "pt" }, "back": { "text": "один", "language": "ru", "transliteration": "odín", "note": "Forma masculina. Feminino: одна (odná). Neutro: одно (odnó)." }, "createdBy": "seed" },
    { "id": "N-02", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Dois (2)", "language": "pt" }, "back": { "text": "два", "language": "ru", "transliteration": "dva", "note": "Masculino/neutro. Feminino: две (dvie)." }, "createdBy": "seed" },
    { "id": "N-03", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Três (3)", "language": "pt" }, "back": { "text": "три", "language": "ru", "transliteration": "tri", "note": "Mesma forma para todos os gêneros." }, "createdBy": "seed" },
    { "id": "N-04", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Quatro (4)", "language": "pt" }, "back": { "text": "четыре", "language": "ru", "transliteration": "chetýre", "note": "Mesma forma para todos os gêneros. Tônica em -ты-." }, "createdBy": "seed" },
    { "id": "N-05", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Cinco (5)", "language": "pt" }, "back": { "text": "пять", "language": "ru", "transliteration": "piat'", "note": "Termina em sinal suave — amolece o T final." }, "createdBy": "seed" },
    { "id": "N-06", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Seis (6)", "language": "pt" }, "back": { "text": "шесть", "language": "ru", "transliteration": "chiest'", "note": "Sinal suave no final. Ш + Е stressed = 'chié'." }, "createdBy": "seed" },
    { "id": "N-07", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Sete (7)", "language": "pt" }, "back": { "text": "семь", "language": "ru", "transliteration": "siem'", "note": "Sinal suave amolece o M final." }, "createdBy": "seed" },
    { "id": "N-08", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Oito (8)", "language": "pt" }, "back": { "text": "восемь", "language": "ru", "transliteration": "vósiem'", "note": "Tônica em во-." }, "createdBy": "seed" },
    { "id": "N-09", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Nove (9)", "language": "pt" }, "back": { "text": "девять", "language": "ru", "transliteration": "diéviat'", "note": "Tônica em де-." }, "createdBy": "seed" },
    { "id": "N-10", "type": "phrase", "category": "numbers", "priority": 1, "front": { "text": "Dez (10)", "language": "pt" }, "back": { "text": "десять", "language": "ru", "transliteration": "diésiat'", "note": "Tônica em де-. Para 11–19, soma-se '-надцать' (одиннадцать, двенадцать…)." }, "createdBy": "seed" },

    { "id": "V-01", "type": "phrase", "category": "vocab", "front": { "text": "Carro", "language": "pt" }, "back": { "text": "машина", "language": "ru", "transliteration": "machína", "note": "Feminino. Plural: машины (machíny). Tb. significa 'máquina'." }, "createdBy": "seed" },
    { "id": "V-02", "type": "phrase", "category": "vocab", "front": { "text": "Mar", "language": "pt" }, "back": { "text": "море", "language": "ru", "transliteration": "móre", "note": "Neutro. Plural: моря (moriá)." }, "createdBy": "seed" },
    { "id": "V-03", "type": "phrase", "category": "vocab", "front": { "text": "Mosca", "language": "pt" }, "back": { "text": "муха", "language": "ru", "transliteration": "múkha", "note": "Feminino. Insecto. Verbo 'voar' é летать (letát')." }, "createdBy": "seed" },
    { "id": "V-04", "type": "phrase", "category": "vocab", "front": { "text": "Rato (mouse)", "language": "pt" }, "back": { "text": "мышь", "language": "ru", "transliteration": "mych'", "note": "Feminino, sinal suave no fim. Vale para o animal e para o mouse de computador." }, "createdBy": "seed" },
    { "id": "V-05", "type": "phrase", "category": "vocab", "front": { "text": "Bola", "language": "pt" }, "back": { "text": "мяч", "language": "ru", "transliteration": "miach", "note": "Masculino. Diminutivo carinhoso: мячик (miáchik)." }, "createdBy": "seed" },
    { "id": "V-06", "type": "phrase", "category": "vocab", "front": { "text": "(Eu) moro / vivo", "language": "pt" }, "back": { "text": "я живу", "language": "ru", "transliteration": "ya jivú", "note": "Verbo жить (viver), 1ª pessoa singular. Tu vives: ты живёшь (ty jiviósh)." }, "createdBy": "seed" },
    { "id": "V-07", "type": "phrase", "category": "vocab", "front": { "text": "(Eu) falo", "language": "pt" }, "back": { "text": "я говорю", "language": "ru", "transliteration": "ya govoriú", "note": "Verbo говорить (falar). Para idiomas: 'я говорю по-русски / по-английски'." }, "createdBy": "seed" },
    { "id": "V-08", "type": "phrase", "category": "vocab", "front": { "text": "(Eu) aprendo / estudo", "language": "pt" }, "back": { "text": "я учу", "language": "ru", "transliteration": "ya uchú", "note": "Verbo учить + acusativo. Também pode significar 'ensinar' dependendo da regência." }, "createdBy": "seed" },

    { "id": "C-01", "type": "phrase", "category": "countries", "front": { "text": "Rússia", "language": "pt" }, "back": { "text": "Россия", "language": "ru", "transliteration": "Rossíia", "note": "Para 'sou da Rússia': Я из России (genitivo)." }, "createdBy": "seed" },
    { "id": "C-02", "type": "phrase", "category": "countries", "front": { "text": "França", "language": "pt" }, "back": { "text": "Франция", "language": "ru", "transliteration": "Frántsia", "note": "Ц soa 'ts'. Tônica em Фра-." }, "createdBy": "seed" },
    { "id": "C-03", "type": "phrase", "category": "countries", "front": { "text": "Itália", "language": "pt" }, "back": { "text": "Италия", "language": "ru", "transliteration": "Itáliia", "note": "Tônica em -та-." }, "createdBy": "seed" },
    { "id": "C-04", "type": "phrase", "category": "countries", "front": { "text": "Alemanha", "language": "pt" }, "back": { "text": "Германия", "language": "ru", "transliteration": "Guermániia", "note": "Г é sempre G forte (como em 'gato')." }, "createdBy": "seed" },
    { "id": "C-05", "type": "phrase", "category": "countries", "front": { "text": "Espanha", "language": "pt" }, "back": { "text": "Испания", "language": "ru", "transliteration": "Ispániia", "note": "Tônica em -па-." }, "createdBy": "seed" },
    { "id": "C-06", "type": "phrase", "category": "countries", "front": { "text": "Brasil", "language": "pt" }, "back": { "text": "Бразилия", "language": "ru", "transliteration": "Brazíliia", "note": "Genitivo: Бразилии (de/da Brasil) — usado em 'Я из Бразилии'." }, "createdBy": "seed" },
    { "id": "C-07", "type": "phrase", "category": "countries", "front": { "text": "EUA / América", "language": "pt" }, "back": { "text": "США / Америка", "language": "ru", "transliteration": "Es-Sha-A / Amiérika", "note": "США lê-se letra por letra: 'es-sha-a'. Coloquial: Америка." }, "createdBy": "seed" },
    { "id": "C-08", "type": "phrase", "category": "countries", "front": { "text": "Inglaterra", "language": "pt" }, "back": { "text": "Англия", "language": "ru", "transliteration": "Ángliia", "note": "Para 'falo inglês': говорю по-английски (po-anglíiski)." }, "createdBy": "seed" },
    { "id": "C-09", "type": "phrase", "category": "countries", "front": { "text": "Japão", "language": "pt" }, "back": { "text": "Япония", "language": "ru", "transliteration": "Yapóniia", "note": "Я no início soa 'ya'. Tônica em -по-." }, "createdBy": "seed" },

    { "id": "F-16", "type": "phrase", "category": "family", "front": { "text": "Sou da Rússia", "language": "pt" }, "back": { "text": "Я из России", "language": "ru", "transliteration": "Ya iz Rossíi", "note": "Из + genitivo (Россия → России). Espelho de F-04 ('Sou do Brasil')." }, "createdBy": "seed" },
    { "id": "F-17", "type": "phrase", "category": "family", "front": { "text": "Sou brasileiro", "language": "pt" }, "back": { "text": "Я бразилец", "language": "ru", "transliteration": "Ya brazíliets", "note": "Masculino. Feminino: бразильянка. Variante coloquial vista na aula: бразильянец." }, "createdBy": "seed" },
    { "id": "F-18", "type": "phrase", "category": "family", "front": { "text": "Moro em Portugal", "language": "pt" }, "back": { "text": "Я живу в Португалии", "language": "ru", "transliteration": "Ya jivú v Portugálii", "note": "В + locativo (Португалия → Португалии). Estrutura idêntica para outros países." }, "createdBy": "seed" },
    { "id": "F-19", "type": "phrase", "category": "family", "front": { "text": "Moro no Porto", "language": "pt" }, "back": { "text": "Я живу в Порто", "language": "ru", "transliteration": "Ya jivú v Pórto", "note": "Порто é estrangeirismo, geralmente indeclinável." }, "createdBy": "seed" },
    { "id": "F-20", "type": "phrase", "category": "family", "front": { "text": "Aprendo português", "language": "pt" }, "back": { "text": "Я учу португальский", "language": "ru", "transliteration": "Ya uchú portugálsky", "note": "Учу + acusativo do adjetivo (subentende-se язык, idioma)." }, "createdBy": "seed" },
    { "id": "F-21", "type": "phrase", "category": "family", "front": { "text": "Falo inglês", "language": "pt" }, "back": { "text": "Я говорю по-английски", "language": "ru", "transliteration": "Ya govoriú po-anglíiski", "note": "Estrutura 'по- + adjetivo de idioma -ски' = falar em [idioma]. Mesma forma para по-русски, по-португальски." }, "createdBy": "seed" },

    { "id": "VRB-01", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "ler (infinitivo)", "language": "pt" }, "back": { "text": "читать", "language": "ru", "transliteration": "chitát'", "note": "Я читаю · Ты читаешь · Он/она читает. 1ª conjugação (-ать)." }, "createdBy": "seed" },
    { "id": "VRB-02", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "olhar / assistir (infinitivo)", "language": "pt" }, "back": { "text": "смотреть", "language": "ru", "transliteration": "smotriét'", "note": "Я смотрю · Ты смотришь · Он/она смотрит. 2ª conjugação (-еть com mutação)." }, "createdBy": "seed" },
    { "id": "VRB-03", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "ouvir / escutar (infinitivo)", "language": "pt" }, "back": { "text": "слушать", "language": "ru", "transliteration": "slúchat'", "note": "Я слушаю · Ты слушаешь · Он/она слушает. 1ª conjugação." }, "createdBy": "seed" },
    { "id": "VRB-04", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "jogar / brincar (infinitivo)", "language": "pt" }, "back": { "text": "играть", "language": "ru", "transliteration": "igrát'", "note": "Я играю · Ты играешь · Он/она играет. Para jogos: играть в + acusativo (играть в футбол)." }, "createdBy": "seed" },
    { "id": "VRB-05", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "trabalhar (infinitivo)", "language": "pt" }, "back": { "text": "работать", "language": "ru", "transliteration": "rabótat'", "note": "Я работаю · Ты работаешь · Он/она работает. 1ª conjugação." }, "createdBy": "seed" },
    { "id": "VRB-06", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "descansar (infinitivo)", "language": "pt" }, "back": { "text": "отдыхать", "language": "ru", "transliteration": "otdykhát'", "note": "Я отдыхаю · Ты отдыхаешь · Он/она отдыхает. 1ª conjugação." }, "createdBy": "seed" },
    { "id": "VRB-07", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "passear (infinitivo)", "language": "pt" }, "back": { "text": "гулять", "language": "ru", "transliteration": "guliát'", "note": "Я гуляю · Ты гуляешь · Он/она гуляет. Caminhar sem destino fixo." }, "createdBy": "seed" },
    { "id": "VRB-08", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "viajar (infinitivo)", "language": "pt" }, "back": { "text": "путешествовать", "language": "ru", "transliteration": "putechiéstvovat'", "note": "Я путешествую · Ты путешествуешь · Он/она путешествует. Conjugação -овать → -у- no presente." }, "createdBy": "seed" },
    { "id": "VRB-09", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "cozinhar / preparar (infinitivo)", "language": "pt" }, "back": { "text": "готовить", "language": "ru", "transliteration": "gotóvit'", "note": "Я готовлю · Ты готовишь · Он/она готовит. Mutação в → вл na 1ª pessoa." }, "createdBy": "seed" },
    { "id": "VRB-10", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "praticar esporte (locução)", "language": "pt" }, "back": { "text": "заниматься спортом", "language": "ru", "transliteration": "zanimát'sia spórtom", "note": "Я занимаюсь · Ты занимаешься · Он/она занимается. Verbo reflexivo (-ся). Pede instrumental: спортом." }, "createdBy": "seed" },
    { "id": "VRB-11", "type": "phrase", "category": "verbs", "priority": 1, "front": { "text": "amar / gostar de (infinitivo)", "language": "pt" }, "back": { "text": "любить", "language": "ru", "transliteration": "liubít'", "note": "Я люблю · Ты любишь · Он/она любит. Mutação б → бл na 1ª pessoa. Pede acusativo direto." }, "createdBy": "seed" },

    { "id": "VC-01", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu leio **livros**.", "language": "pt" }, "back": { "text": "Я читаю **книги**.", "language": "ru", "transliteration": "Ya chitáiu knígi.", "note": "книга (f) — livro. Plural: книги. Aqui acusativo = nominativo (inanimado)." }, "createdBy": "seed" },
    { "id": "VC-02", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu assisto **filmes**.", "language": "pt" }, "back": { "text": "Я смотрю **фильмы**.", "language": "ru", "transliteration": "Ya smotriú fíl'my.", "note": "фильм (m) — filme. Plural: фильмы (-ы após consoante dura)." }, "createdBy": "seed" },
    { "id": "VC-03", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu adoro **música**.", "language": "pt" }, "back": { "text": "Я люблю **музыку**.", "language": "ru", "transliteration": "Ya liubliú múzyku.", "note": "музыка (f) — música. Aqui no acusativo: музыку (-а → -у)." }, "createdBy": "seed" },
    { "id": "VC-04", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu pratico **esporte**.", "language": "pt" }, "back": { "text": "Я занимаюсь **спортом**.", "language": "ru", "transliteration": "Ya zanimáius' spórtom.", "note": "спорт (m) — esporte. Aqui no instrumental: спортом (-ом)." }, "createdBy": "seed" },
    { "id": "VC-05", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu jogo **futebol**.", "language": "pt" }, "back": { "text": "Я играю в **футбол**.", "language": "ru", "transliteration": "Ya igráiu v futból.", "note": "футбол (m) — futebol. Após 'играть в' o substantivo vai para o acusativo (= nominativo aqui, inanimado)." }, "createdBy": "seed" },
    { "id": "VC-06", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu adoro **café**.", "language": "pt" }, "back": { "text": "Я люблю **кофе**.", "language": "ru", "transliteration": "Ya liubliú kófie.", "note": "кофе (m) — café. Indeclinável (estrangeirismo): mesma forma em todos os casos." }, "createdBy": "seed" },
    { "id": "VC-07", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu bebo **chá**.", "language": "pt" }, "back": { "text": "Я пью **чай**.", "language": "ru", "transliteration": "Ya p'iu chai.", "note": "чай (m) — chá. Aqui no acusativo = nominativo (inanimado). Verbo пить (beber): я пью, ты пьёшь." }, "createdBy": "seed" },
    { "id": "VC-08", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu passeio com **um amigo**.", "language": "pt" }, "back": { "text": "Я гуляю с **другом**.", "language": "ru", "transliteration": "Ya guliáiu s drúgom.", "note": "друг (m) — amigo. С + instrumental: другом. Fem.: подруга (instrumental: подругой). Pl.: друзья (irregular)." }, "createdBy": "seed" },
    { "id": "VC-09", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu moro na **cidade**.", "language": "pt" }, "back": { "text": "Я живу в **городе**.", "language": "ru", "transliteration": "Ya jivú v górodie.", "note": "город (m) — cidade. В + locativo: городе (-е). Pl.: города (tônica desloca)." }, "createdBy": "seed" },
    { "id": "VC-10", "type": "phrase", "category": "vocab", "priority": 1, "front": { "text": "Eu passeio no **parque**.", "language": "pt" }, "back": { "text": "Я гуляю в **парке**.", "language": "ru", "transliteration": "Ya guliáiu v párkie.", "note": "парк (m) — parque. В + locativo: парке (-е)." }, "createdBy": "seed" },

