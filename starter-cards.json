    { "id": "R-01", "type": "phrase", "category": "romantic", "front": { "text": "Eu te amo", "language": "pt" }, "back": { "text": "Я тебя люблю", "language": "ru", "transliteration": "Ya tibiá liubliú", "note": "A frase clássica. Informal, entre casal." }, "createdBy": "seed" },
    { "id": "R-02", "type": "phrase", "category": "romantic", "front": { "text": "Sinto sua falta", "language": "pt" }, "back": { "text": "Я скучаю по тебе", "language": "ru", "transliteration": "Ya skucháiu po tibié", "note": "Literalmente 'me entedio por você' — é assim que se diz 'ter saudade'." }, "createdBy": "seed" },
    { "id": "R-03", "type": "phrase", "category": "romantic", "front": { "text": "Você é linda", "language": "pt" }, "back": { "text": "Ты красивая", "language": "ru", "transliteration": "Ty krasívaia", "note": "Feminino. Para homem: красивый (krasívy)." }, "createdBy": "seed" },
    { "id": "R-04", "type": "phrase", "category": "romantic", "front": { "text": "Me beija", "language": "pt" }, "back": { "text": "Поцелуй меня", "language": "ru", "transliteration": "Potselúi miniá", "note": "Imperativo, carinhoso." }, "createdBy": "seed" },
    { "id": "R-05", "type": "phrase", "category": "romantic", "front": { "text": "Me abraça", "language": "pt" }, "back": { "text": "Обними меня", "language": "ru", "transliteration": "Obnimí miniá", "note": "Imperativo." }, "createdBy": "seed" },
    { "id": "R-06", "type": "phrase", "category": "romantic", "front": { "text": "Você é minha vida", "language": "pt" }, "back": { "text": "Ты моя жизнь", "language": "ru", "transliteration": "Ty maiá jizn'", "note": "Forte e dramático — use com parcimônia." }, "createdBy": "seed" },
    { "id": "R-07", "type": "phrase", "category": "romantic", "front": { "text": "Estou bem com você", "language": "pt" }, "back": { "text": "С тобой хорошо", "language": "ru", "transliteration": "S tobói khorochó", "note": "Literalmente 'com você é bom' — expressão comum." }, "createdBy": "seed" },
    { "id": "R-08", "type": "phrase", "category": "romantic", "front": { "text": "Meu sol (querida)", "language": "pt" }, "back": { "text": "Солнышко моё", "language": "ru", "transliteration": "Sólnychko maió", "note": "Apelido carinhoso literalmente 'solzinho meu'. Neutro, serve para ele ou ela." }, "createdBy": "seed" },
    { "id": "R-09", "type": "phrase", "category": "romantic", "front": { "text": "Minha coelhinha", "language": "pt" }, "back": { "text": "Зайка моя", "language": "ru", "transliteration": "Záika maiá", "note": "Apelido muito comum entre casais na Rússia." }, "createdBy": "seed" },
    { "id": "R-10", "type": "phrase", "category": "romantic", "front": { "text": "Boa noite, meu amor", "language": "pt" }, "back": { "text": "Спокойной ночи, любимая", "language": "ru", "transliteration": "Spokóinoi nóchi, liubímaia", "note": "Para ela. Para ele: любимый (liubímy)." }, "createdBy": "seed" },
    { "id": "R-11", "type": "phrase", "category": "romantic", "front": { "text": "Bom dia, querida", "language": "pt" }, "back": { "text": "Доброе утро, милая", "language": "ru", "transliteration": "Dóbroie útro, mílaia", "note": "Usa-se até umas 11h. Depois: добрый день." }, "createdBy": "seed" },
    { "id": "R-12", "type": "phrase", "category": "romantic", "front": { "text": "Quero estar com você", "language": "pt" }, "back": { "text": "Я хочу быть с тобой", "language": "ru", "transliteration": "Ya khochú byt' s tobói", "note": "Declaração simples e direta." }, "createdBy": "seed" },
    { "id": "R-13", "type": "phrase", "category": "romantic", "front": { "text": "Você é a melhor", "language": "pt" }, "back": { "text": "Ты самая лучшая", "language": "ru", "transliteration": "Ty sámaia lútchchaia", "note": "Feminino. Para ele: самый лучший (sámy lútchchy)." }, "createdBy": "seed" },
    { "id": "R-14", "type": "phrase", "category": "romantic", "front": { "text": "Estou pensando em você", "language": "pt" }, "back": { "text": "Я думаю о тебе", "language": "ru", "transliteration": "Ya dúmaiu o tibié", "note": "Perfeito para uma mensagem no meio do dia." }, "createdBy": "seed" },
    { "id": "R-15", "type": "phrase", "category": "romantic", "front": { "text": "Você é meu mundo", "language": "pt" }, "back": { "text": "Ты весь мой мир", "language": "ru", "transliteration": "Ty ves' moi mir", "note": "Mir também significa 'paz' — um dos duplos sentidos favoritos do russo." }, "createdBy": "seed" },

    { "id": "F-01", "type": "phrase", "category": "family", "front": { "text": "Olá (formal)", "language": "pt" }, "back": { "text": "Здравствуйте", "language": "ru", "transliteration": "Zdrávstvuite", "note": "Formal, plural. Obrigatório com os pais dela no primeiro contato." }, "createdBy": "seed" },
    { "id": "F-02", "type": "phrase", "category": "family", "front": { "text": "Muito prazer", "language": "pt" }, "back": { "text": "Очень приятно", "language": "ru", "transliteration": "Óchen' priátno", "note": "Ao ser apresentado. Combina com um aperto de mão firme." }, "createdBy": "seed" },
    { "id": "F-03", "type": "phrase", "category": "family", "front": { "text": "Me chamo Lucas", "language": "pt" }, "back": { "text": "Меня зовут Лукас", "language": "ru", "transliteration": "Miniá zovút Lúkas", "note": "Literalmente 'me chamam Lucas'. Troque o nome se quiser." }, "createdBy": "seed" },
    { "id": "F-04", "type": "phrase", "category": "family", "front": { "text": "Sou do Brasil", "language": "pt" }, "back": { "text": "Я из Бразилии", "language": "ru", "transliteration": "Ya iz Brazílii", "note": "Из = 'de' (procedência)." }, "createdBy": "seed" },
    { "id": "F-05", "type": "phrase", "category": "family", "front": { "text": "Muito obrigado", "language": "pt" }, "back": { "text": "Спасибо большое", "language": "ru", "transliteration": "Spasíbo bolchóie", "note": "Literalmente 'obrigado grande'. Spasíbo sozinho também serve." }, "createdBy": "seed" },
    { "id": "F-06", "type": "phrase", "category": "family", "front": { "text": "Está muito gostoso", "language": "pt" }, "back": { "text": "Очень вкусно", "language": "ru", "transliteration": "Óchen' vkúsno", "note": "A frase de ouro no jantar da família dela." }, "createdBy": "seed" },
    { "id": "F-07", "type": "phrase", "category": "family", "front": { "text": "Desculpe (formal)", "language": "pt" }, "back": { "text": "Извините", "language": "ru", "transliteration": "Izvinítie", "note": "Formal. Informal: извини (izviní)." }, "createdBy": "seed" },
    { "id": "F-08", "type": "phrase", "category": "family", "front": { "text": "Posso repetir (mais)?", "language": "pt" }, "back": { "text": "Можно ещё?", "language": "ru", "transliteration": "Mójno ieschió?", "note": "No jantar, quando querem ver você comer mais. Diga 'sim' se gostou." }, "createdBy": "seed" },
    { "id": "F-09", "type": "phrase", "category": "family", "front": { "text": "Me ajude, por favor", "language": "pt" }, "back": { "text": "Помогите, пожалуйста", "language": "ru", "transliteration": "Pomogítie, pojálusta", "note": "Formal. 'Пожалуйста' (por favor) pronuncia-se 'pojálsta' — o 'lu' quase some." }, "createdBy": "seed" },
    { "id": "F-10", "type": "phrase", "category": "family", "front": { "text": "Não entendo", "language": "pt" }, "back": { "text": "Я не понимаю", "language": "ru", "transliteration": "Ya ne ponimáiu", "note": "Use sem vergonha — ajuda a baixar o ritmo da conversa." }, "createdBy": "seed" },
    { "id": "F-11", "type": "phrase", "category": "family", "front": { "text": "Fale mais devagar, por favor", "language": "pt" }, "back": { "text": "Говорите медленнее, пожалуйста", "language": "ru", "transliteration": "Govorítie miédlennie, pojálusta", "note": "Frase que salva vidas em qualquer conversa." }, "createdBy": "seed" },
    { "id": "F-12", "type": "phrase", "category": "family", "front": { "text": "Como vai? (formal)", "language": "pt" }, "back": { "text": "Как дела?", "language": "ru", "transliteration": "Kak dielá?", "note": "Informal também. Resposta padrão: 'Хорошо' (khorochó — bem)." }, "createdBy": "seed" },
    { "id": "F-13", "type": "phrase", "category": "family", "front": { "text": "Estou aprendendo russo", "language": "pt" }, "back": { "text": "Я учу русский", "language": "ru", "transliteration": "Ya uchú rússky", "note": "Frase-passaporte. Costuma provocar sorrisos." }, "createdBy": "seed" },
    { "id": "F-14", "type": "phrase", "category": "family", "front": { "text": "Repita, por favor", "language": "pt" }, "back": { "text": "Повторите, пожалуйста", "language": "ru", "transliteration": "Povtorítie, pojálusta", "note": "Formal. Informal: повтори (povtorí)." }, "createdBy": "seed" },
    { "id": "F-15", "type": "phrase", "category": "family", "front": { "text": "Mãe, pai", "language": "pt" }, "back": { "text": "Мама, папа", "language": "ru", "transliteration": "Máma, pápa", "note": "Usado também ao falar DA mãe/pai de alguém, não só dos seus." }, "createdBy": "seed" },

